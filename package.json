{
  "name": "plasticman-vs-flash",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Plastic Man vs The Flash — a comic-book agent showdown. Vite + React front end with a thin Express backend that proxies OpenAI so the key stays server-side.",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "PORT=3001 node --watch server/index.js",
    "server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "vite": "^6.0.7"
  }
}
