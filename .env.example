# Copy to .env and fill in. .env is gitignored — never commit real keys.

# OpenAI API key — used by the server-side chat proxy (/api/chat).
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI model the multi-agent fight uses.
# Lightweight GPT-5 family: gpt-5-nano (lightest) or gpt-5-mini (default).
OPENAI_MODEL=gpt-5-mini

# Backend HTTP port.
PORT=3001
